<footer class="site-footer" id="footer">
    <div class="container footer-grid">
        <div class="footer-col">
            <span class="brand-name light">web<strong>Furniture</strong></span>
            <p class="footer-desc"><%= t.common.tagline %></p>
            <p><%= t.common.footer.address %></p>
            <p><%= t.common.footer.email %></p>
            <p><%= t.common.footer.website %></p>
        </div>

        <div class="footer-col">
            <h4><%= t.common.footer.services %></h4>
            <ul>
                <% t.common.footer.svcList.forEach(function (s) { %>
                    <li><a href="#"><%= s %></a></li>
                <% }) %>
            </ul>
        </div>

        <div class="footer-col">
            <h4><%= t.common.footer.contact %></h4>
            <p><%= t.common.footer.address %></p>
            <p><%= t.common.footer.phone %></p>
            <p><%= t.common.footer.email %></p>
            <div class="socials">
                <a href="#" aria-label="facebook">f</a>
                <a href="#" aria-label="youtube">▶</a>
                <a href="#" aria-label="instagram">◎</a>
            </div>
        </div>

        <div class="footer-col hotline-col">
            <h4><%= t.common.footer.hotline %></h4>
            <p class="hotline"><%= t.common.footer.phone %></p>
            <p><%= t.common.footer.tax %></p>
        </div>
    </div>

    <div class="footer-bottom">
        <div class="container footer-bottom-inner">
            <span>© 2026 webFurniture. <%= t.common.footer.rights %> · <%= t.common.footer.tax %></span>
            <a class="footer-admin" href="/admin">🔒 <%= t.common.footer.admin %></a>
        </div>
    </div>
</footer>
