<%- include('partials/head') %>
<body>
<%- include('partials/header') %>

<!-- ── HERO / Slideshow (spec 3.2 · animation) ─────────────────────────────── -->
<section class="hero">
    <div class="hero-track" id="heroTrack">
        <% heroSlides.forEach(function (s) { %>
            <div class="hero-slide" style="background-image:url('<%= s.image %>')">
                <div class="container hero-content">
                    <% if (pick(s, 'badge')) { %><span class="hero-badge"><%= pick(s, 'badge') %></span><% } %>
                    <h1 class="hero-title"><%= pick(s, 'title') %></h1>
                    <%# Nút "Mua ngay" đã bỏ theo yêu cầu — slide chỉ còn ảnh + badge + tiêu đề %>
                </div>
            </div>
        <% }) %>
    </div>
    <button class="hero-arrow prev" data-dir="-1" aria-label="prev">&lsaquo;</button>
    <button class="hero-arrow next" data-dir="1" aria-label="next">&rsaquo;</button>
    <div class="hero-dots" id="heroDots">
        <% heroSlides.forEach(function (_, i) { %>
            <button class="dot <%= i === 0 ? 'active' : '' %>" data-idx="<%= i %>" aria-label="slide <%= i + 1 %>"></button>
        <% }) %>
    </div>
</section>

<!-- ── Khối Công năng (từ DB · /admin/features) ────────────────────────────── -->
<!-- Cả section nằm trong if: không dùng idiom <p class="empty"> như các mục khác,
     vì "đang tắt" phải là biến mất hẳn chứ không phải một ô xám "chưa có dữ liệu". -->
<% if (features.length) { %>
    <section class="features">
        <div class="container">
            <ul class="feature-strip">
                <% features.forEach(function (f) { %>
                    <%# tabindex="0" là bắt buộc: không có phần tử nhận focus thì
                        :focus-within không bao giờ kích hoạt -> bàn phím không đọc được mô tả %>
                    <li class="feature-item" tabindex="0" role="group">
                        <img class="feature-icon" src="<%= f.icon %>" alt="" loading="lazy">
                        <h3 class="feature-title"><%= pick(f, 'title') %></h3>
                        <% if (pick(f, 'description')) { %>
                            <p class="feature-desc"><%= pick(f, 'description') %></p>
                        <% } %>
                    </li>
                <% }) %>
            </ul>
        </div>
    </section>
<% } %>

<!-- ── Showcase sản phẩm nổi bật — tràn màn hình, 4 ảnh/khung ──────────────── -->
<!-- Nằm NGOÀI .container để tràn hết bề ngang. Lấy 8 sản phẩm, hiện 4, còn lại
     kéo bằng 2 nút ở giữa hai mép. -->
<% if (showcase.length) { %>
    <section class="showcase">
        <div class="showcase-track" id="showcaseTrack">
            <% showcase.forEach(function (p) { %>
                <a class="showcase-item" href="/products/<%= p.id %>">
                    <div class="showcase-media">
                        <img src="<%= p.thumbnail || ('https://picsum.photos/seed/p' + p.id + '/600/750') %>"
                             alt="<%= pick(p, 'name') %>" loading="lazy">
                    </div>
                    <div class="showcase-info">
                        <% if (p.category) { %><span class="showcase-cat"><%= pick(p.category, 'name') %></span><% } %>
                        <h3 class="showcase-name"><%= pick(p, 'name') %></h3>
                    </div>
                </a>
            <% }) %>
        </div>

        <%# data-scroll-by-item: cuộn đúng bề ngang 1 ảnh thay vì 260px cứng %>
        <button class="showcase-arrow prev" type="button"
                data-scroll="showcaseTrack" data-scroll-by-item data-dir="-1"
                aria-label="<%= t.common.actions.prev %>">&lsaquo;</button>
        <button class="showcase-arrow next" type="button"
                data-scroll="showcaseTrack" data-scroll-by-item data-dir="1"
                aria-label="<%= t.common.actions.next %>">&rsaquo;</button>
    </section>
<% } %>

<!-- ── Why us (spec 3.2 · Thông tin doanh nghiệp) — tiêu đề + 1 đoạn, căn giữa ─ -->
<section class="section why" id="why">
    <div class="container why-intro">
        <h2 class="section-title"><%= t.home.why.title %></h2>
        <p class="why-body"><%= t.home.why.body %></p>
    </div>
</section>

<!-- ── Categories (spec 3.2 · Loại sản phẩm — TỪ DB) ───────────────────────── -->
<section class="section categories" id="categories">
    <div class="container cat-layout">

        <%# Cột trái: chữ. Tiêu đề + mô tả sửa ở /admin/content, song ngữ.
            Cố ý không có nút CTA ở đây — theo yêu cầu đã bỏ nút cuối khối. %>
        <div class="cat-intro">
            <h2 class="cat-intro-title"><%= categoriesTitle %></h2>
            <p class="cat-intro-desc"><%= categoriesDesc %></p>
            <% if (categories.length > 1) { %>
                <div class="cat-nav">
                    <button class="round-btn" data-scroll="cats" data-scroll-by-item data-dir="-1"
                            aria-label="<%= t.common.actions.prev %>">&lsaquo;</button>
                    <button class="round-btn" data-scroll="cats" data-scroll-by-item data-dir="1"
                            aria-label="<%= t.common.actions.next %>">&rsaquo;</button>
                </div>
            <% } %>
        </div>

        <!-- Cột phải: ảnh loại sản phẩm, tên nằm GIỮA ảnh -->
        <% if (categories.length) { %>
            <div class="cat-track" id="cats">
                <% categories.forEach(function (c) { %>
                    <%# tabindex để bàn phím cũng mở được lớp danh mục con (:focus-within) %>
                    <div class="cat-card" tabindex="0"
                         style="background-image:url('<%= c.image || ('https://picsum.photos/seed/cat' + c.id + '/700/560') %>')">
                        <a class="cat-card-link" href="/categories/<%= c.id %>">
                            <span class="cat-label"><%= pick(c, 'name') %></span>
                        </a>

                        <% if (c.children.length) { %>
                            <div class="cat-subs">
                                <span class="cat-subs-head"><%= pick(c, 'name') %></span>
                                <ul class="cat-subs-list">
                                    <% c.children.forEach(function (ch) { %>
                                        <li>
                                            <a href="/categories/<%= ch.id %>">
                                                <span class="cat-sub-thumb"
                                                      style="background-image:url('<%= ch.image || ('https://picsum.photos/seed/cat' + ch.id + '/300/300') %>')"></span>
                                                <span class="cat-sub-name"><%= pick(ch, 'name') %></span>
                                            </a>
                                        </li>
                                    <% }) %>
                                </ul>
                            </div>
                        <% } %>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <p class="empty"><%= t.common.empty %></p>
        <% } %>
    </div>
</section>

<!-- ── Partners (spec 3.2 · Đối tác hợp tác) ───────────────────────────────── -->
<%# ── Lưới ảnh "Style advice" — ảnh TĨNH, không còn xoay vòng.
    · 3 ô lớn: từ DB theo khe cố định (sửa ở /admin/gallery).
    · 5 ô nhỏ: đóng cứng trong home.controller.js (SMALL_TILES), admin KHÔNG sửa.
    · Chữ tiêu đề cũng đóng cứng (t.home.gallery). %>
<section class="section gallery-grid-section" id="inspiration">
    <div class="container">
        <div class="gallery-head">
            <h2 class="gallery-title"><%= t.home.gallery.title %></h2>
            <p class="gallery-sub"><%= t.home.gallery.sub %></p>
        </div>

        <div class="collage" id="collage">
            <% galleryBig.forEach(function (g, k) { %>
                <figure class="collage-cell is-big big-<%= k + 1 %>">
                    <img class="collage-img" src="<%= g.image %>" alt="<%= pick(g, 'alt') %>">
                </figure>
            <% }) %>

            <% gallerySmall.forEach(function (g, k) { %>
                <figure class="collage-cell small-<%= k + 1 %>">
                    <img class="collage-img" src="<%= g.image %>" alt="<%= pick(g, 'alt') %>" loading="lazy">
                </figure>
            <% }) %>
        </div>
    </div>
</section>

<%# ── Tin tức: header canh giữa + lưới bài viết 2 cột (ảnh → tiêu đề → mô tả → link) %>
<% if (news.length) { %>
    <section class="section news" id="news">
        <div class="container">
            <div class="news-head">
                <h2 class="news-title"><%= newsTitle %></h2>
                <p class="news-desc"><%= newsDesc %></p>
                <% if (newsCta) { %>
                    <a class="news-cta" href="<%= newsCtaLink %>"><%= newsCta %> <span aria-hidden="true">&rarr;</span></a>
                <% } %>
            </div>

            <div class="news-grid">
                <% news.forEach(function (n) { %>
                    <article class="news-card">
                        <%# Ảnh LUÔN mở bài viết, cố ý không dùng `n.link`: ảnh là
                            thumbnail của bài nên bấm vào phải ra đúng bài đó. Ô
                            "Link ngoài" trong admin chỉ chi phối nút CTA bên dưới. %>
                        <a class="news-card-media" href="/news/<%= n.id %>">
                            <img src="<%= n.image %>" alt="<%= pick(n, 'title') %>" loading="lazy">
                        </a>
                        <h3 class="news-card-title"><%= pick(n, 'title') %></h3>
                        <% if (pick(n, 'excerpt')) { %>
                            <p class="news-card-desc"><%= pick(n, 'excerpt') %></p>
                        <% } %>
                        <% if (pick(n, 'cta')) { %>
                            <a class="news-card-cta" href="<%= n.link || ('/news/' + n.id) %>">
                                <span aria-hidden="true">&rarr;</span> <%= pick(n, 'cta') %>
                            </a>
                        <% } %>
                    </article>
                <% }) %>
            </div>
        </div>
    </section>
<% } %>

<section class="section partners" id="partners">
    <div class="container">
        <p class="partners-sub"><%= t.home.partners.sub %></p>
        <h2 class="section-title center"><%= t.home.partners.title %></h2>
        <div class="partner-row">
            <% partners.forEach(function (p) { %>
                <% if (p.link) { %>
                    <a class="partner-logo" href="<%= p.link %>" target="_blank" rel="noopener"><% if (p.logo) { %><img src="<%= p.logo %>" alt="<%= p.name %>"><% } else { %><%= p.name %><% } %></a>
                <% } else { %>
                    <span class="partner-logo"><% if (p.logo) { %><img src="<%= p.logo %>" alt="<%= p.name %>"><% } else { %><%= p.name %><% } %></span>
                <% } %>
            <% }) %>
        </div>
    </div>
</section>

<!-- ── Certificates (spec 3.2 · Giấy chứng nhận công ty) ───────────────────── -->
<section class="section certs">
    <div class="container">
        <h2 class="section-title center"><%= t.home.certs.title %></h2>
        <div class="cert-row">
            <% certificates.forEach(function (c) { %>
                <%# Bỏ figcaption theo yêu cầu — chỉ còn ảnh. Tên chứng nhận vẫn
                    giữ ở `alt` để trình đọc màn hình và SEO còn đọc được. %>
                <figure class="cert-card">
                    <img src="<%= c.image %>" alt="<%= pick(c, 'title') %>" loading="lazy">
                </figure>
            <% }) %>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
<script src="/static/js/main.js?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : '1' %>"></script>
</body>
</html>
