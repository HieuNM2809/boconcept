<%- include('partials/head') %>
<body>
<%- include('partials/header') %>

<% if (!category) { %>
    <section class="section">
        <div class="container center">
            <h2 class="section-title"><%= t.catalog.notFound %></h2>
            <a class="btn btn-outline" href="/"><%= t.catalog.backHome %></a>
        </div>
    </section>
<% } else { %>
    <div class="container listing">

        <!-- Breadcrumb -->
        <nav class="breadcrumb">
            <a href="/"><%= t.catalog.home %></a>
            <% breadcrumb.forEach(function (b) { %>
                <span class="sep">/</span>
                <a href="/categories/<%= b.id %>"><%= pick(b, 'name') %></a>
            <% }) %>
        </nav>

        <%
        /* Dải "Nội thất thiết kế": chữ bên trái, băng ảnh loại sản phẩm cuộn ngang bên phải.

           Lấy từ `navCategories` (navigation.middleware) chứ KHÔNG thêm biến mới ở
           controller: middleware đó chạy cho mọi request và không bao giờ throw, nên
           không phát sinh nguy cơ thiếu biến. Vẫn guard `typeof` cho chắc.

           Bỏ chính loại đang xem ra khỏi dải — hiện lại đúng trang người ta đang
           đứng thì vừa thừa vừa dễ tưởng bấm nhầm. */
        const designCats = ((typeof navCategories !== 'undefined' && navCategories) || [])
            .filter(function (c) { return c.id !== category.id; });
        %>
        <%# Section KHÔNG còn bọc trong `if (designCats.length)`: nó giờ mang <h1> tên
            loại sản phẩm, mà loại nào cũng phải có tên. Loại duy nhất (không còn
            loại nào khác để xếp vào dải ảnh) mà ẩn cả section thì trang mất trắng
            tiêu đề. Chỉ DẢI ẢNH mới nằm trong if. %>
        <section class="design-strip<%= designCats.length ? '' : ' is-solo' %>">
            <div class="design-intro">
                <%# <h1> chứ không <h2>: tiêu đề lớn ở .cat-header đã bỏ theo yêu cầu,
                    đây là tiêu đề chính duy nhất của trang. Ưu tiên tiêu đề riêng
                    admin nhập, không có thì lấy tên loại — y như .cat-heading cũ. %>
                <h1 class="design-title"><%= pick(category, 'title') || pick(category, 'name') %></h1>
                <a class="design-cta" href="/#categories">
                    <span class="design-cta-icon" aria-hidden="true">→</span><%= t.catalog.design.cta %>
                </a>
            </div>

            <% if (designCats.length) { %>
                <div class="design-rail">
                    <div class="design-track" id="designTrack">
                        <% designCats.forEach(function (c) { %>
                            <a class="design-card" href="/categories/<%= c.id %>">
                                <span class="design-card-media"
                                      style="background-image:url('<%= c.image || ('https://picsum.photos/seed/cat' + c.id + '/500/500') %>')"></span>
                                <span class="design-card-label"><%= pick(c, 'name') %></span>
                            </a>
                        <% }) %>
                    </div>
                    <% if (designCats.length > 2) { %>
                        <button class="design-arrow prev" type="button"
                                data-scroll="designTrack" data-scroll-by-item data-dir="-1"
                                aria-label="<%= t.common.actions.prev %>">&lsaquo;</button>
                        <button class="design-arrow next" type="button"
                                data-scroll="designTrack" data-scroll-by-item data-dir="1"
                                aria-label="<%= t.common.actions.next %>">&rsaquo;</button>
                    <% } %>
                </div>
            <% } %>
        </section>

        <%# Đầu trang giờ CHỈ còn phần mô tả. Dải chip danh mục con (.cat-subnav) đã bỏ
            theo yêu cầu — đường vào danh mục con vẫn còn ở băng ảnh .design-strip phía
            trên và ở menu header, nên bỏ chip không mất lối điều hướng nào.
            Tiêu đề lớn bên phải cũng đã bỏ trước đó: tên loại nằm ở <h1> trong
            .design-strip, để cả hai là lặp một cái tên hai lần trên cùng màn hình. %>
        <% if (descriptionHtml) { %>
            <div class="cat-header">
                <%# <div> chứ không <p>: richtext.render sinh ra <p>/<ul>/<h2>,
                    lồng <ul> trong <p> là HTML sai, trình duyệt sẽ tự tách thẻ và vỡ layout. %>
                <div class="cat-heading-wrap">
                    <div class="cat-heading-desc"><%- descriptionHtml %></div>
                </div>
            </div>
        <% } %>

        <!-- Bộ lọc: tên · kích thước · chất liệu · khối lượng -->
        <form class="filter-bar" action="/categories/<%= category.id %>" method="get">
            <input type="hidden" name="sort" value="<%= filters.sort %>">
            <div class="filter-field">
                <label for="f-q"><%= t.catalog.filters.name %></label>
                <input id="f-q" name="q" value="<%= filters.q || '' %>" placeholder="<%= t.catalog.filters.namePh %>">
            </div>
            <div class="filter-field">
                <label for="f-size"><%= t.catalog.filters.size %></label>
                <input id="f-size" name="dimensions" value="<%= filters.dimensions || '' %>" placeholder="<%= t.catalog.filters.sizePh %>">
            </div>
            <div class="filter-field">
                <label for="f-mat"><%= t.catalog.filters.material %></label>
                <input id="f-mat" name="material" value="<%= filters.material || '' %>" placeholder="<%= t.catalog.filters.materialPh %>">
            </div>
            <div class="filter-field">
                <label><%= t.catalog.filters.weight %></label>
                <div class="filter-range">
                    <input type="number" step="0.1" min="0" name="min_weight" value="<%= filters.min_weight || '' %>" aria-label="<%= t.catalog.filters.weightFrom %>" placeholder="<%= t.catalog.filters.weightFrom %>">
                    <span>–</span>
                    <input type="number" step="0.1" min="0" name="max_weight" value="<%= filters.max_weight || '' %>" aria-label="<%= t.catalog.filters.weightTo %>" placeholder="<%= t.catalog.filters.weightTo %>">
                </div>
            </div>
            <div class="filter-actions">
                <button class="btn btn-primary" type="submit"><%= t.catalog.filters.apply %></button>
                <a class="btn btn-outline" href="/categories/<%= category.id %>"><%= t.catalog.filters.clear %></a>
            </div>
        </form>

        <%# Ô "Tìm loại sản phẩm" đã bỏ cùng với dải chip: nó chỉ lọc đúng các chip đó,
            giữ lại thì gõ gì cũng ra "không tìm thấy". %>

        <!-- Thanh sắp xếp + số kết quả -->
        <div class="toolbar">
            <div class="sort-chips">
                <span class="toolbar-label"><%= t.catalog.sortBy %></span>
                <a class="chip <%= filters.sort === 'popular' ? 'active' : '' %>" href="<%= linkFor({sort: 'popular', page: 1}) %>"><%= t.catalog.sort.popular %></a>
                <a class="chip <%= filters.sort === 'newest' ? 'active' : '' %>" href="<%= linkFor({sort: 'newest', page: 1}) %>"><%= t.catalog.sort.newest %></a>
                <a class="chip <%= filters.sort === 'price_asc' ? 'active' : '' %>" href="<%= linkFor({sort: 'price_asc', page: 1}) %>"><%= t.catalog.sort.price_asc %></a>
                <a class="chip <%= filters.sort === 'price_desc' ? 'active' : '' %>" href="<%= linkFor({sort: 'price_desc', page: 1}) %>"><%= t.catalog.sort.price_desc %></a>
            </div>
            <div class="toolbar-right">
                <span class="listing-count"><%= meta.total %> <%= t.catalog.results %></span>
            </div>
        </div>

        <!-- Lưới sản phẩm -->
        <% if (products.length) { %>
            <%# Lưới CỐ ĐỊNH 4 cột; controller giới hạn 12/trang -> đúng 4×3 %>
            <div class="product-grid listing-grid cat-grid">
                <% products.forEach(function (p) { %>
                    <a class="product-card" href="/products/<%= p.id %>">
                        <div class="product-thumb" style="background-image:url('<%= p.thumbnail || ('https://picsum.photos/seed/p' + p.id + '/400') %>')">
                            <% if (p.is_featured) { %><span class="badge-hot">HOT</span><% } %>
                        </div>
                        <div class="product-info">
                            <h3 class="product-name"><%= pick(p, 'name') %></h3>

                            <%# Chất liệu · màu — chỉ hiện khi admin có nhập %>
                            <% const mat = pick(p, 'material'); const col = pick(p, 'color'); %>
                            <% if (mat || col) { %>
                                <p class="product-attr">
                                    <%= [mat, col].filter(Boolean).join(' · ') %>
                                </p>
                            <% } %>

                            <% if (pick(p, 'dimensions')) { %>
                                <p class="product-dims">
                                    <span class="product-dims-label"><%= t.catalog.attrs.size %>:</span>
                                    <%= pick(p, 'dimensions') %>
                                </p>
                            <% } %>
                            <% if (p.weight != null) { %>
                                <p class="product-dims"><span class="product-dims-label"><%= t.catalog.attrs.weight %>:</span> <%= Number(p.weight) %> kg</p>
                            <% } %>

<%# Giá đã bỏ khỏi TOÀN BỘ trang khách xem theo yêu cầu — khách hỏi giá qua form liên hệ. %>
                        </div>
                    </a>
                <% }) %>
            </div>

            <!-- Phân trang -->
            <% if (meta.last_page > 1) { %>
                <nav class="pagination">
                    <% if (meta.current_page > 1) { %>
                        <a class="pg-arrow" href="<%= linkFor({page: meta.current_page - 1}) %>">&lsaquo;</a>
                    <% } else { %><span class="pg-arrow disabled">&lsaquo;</span><% } %>

                    <% pages.forEach(function (p) { %>
                        <% if (p === '…') { %>
                            <span class="pg-ellipsis">…</span>
                        <% } else { %>
                            <a class="pg-num <%= p === meta.current_page ? 'active' : '' %>" href="<%= linkFor({page: p}) %>"><%= p %></a>
                        <% } %>
                    <% }) %>

                    <% if (meta.current_page < meta.last_page) { %>
                        <a class="pg-arrow" href="<%= linkFor({page: meta.current_page + 1}) %>">&rsaquo;</a>
                    <% } else { %><span class="pg-arrow disabled">&rsaquo;</span><% } %>
                </nav>
            <% } %>
        <% } else { %>
            <p class="empty listing-empty"><%= t.catalog.empty %></p>
        <% } %>
    </div>
<% } %>

<%- include('partials/footer') %>
<script src="/static/js/main.js?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : '1' %>"></script>
</body>
</html>
