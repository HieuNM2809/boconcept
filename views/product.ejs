<%- include('partials/head') %>
<body>
<%- include('partials/header') %>

<% if (!product) { %>
    <section class="section">
        <div class="container center">
            <h2 class="section-title"><%= t.product.notFound %></h2>
            <a class="btn btn-outline" href="/"><%= t.product.backHome %></a>
        </div>
    </section>
<% } else { %>
    <% const dv = (product.variants && product.variants.length) ? product.variants[0] : null; %>
    <% const initSku = (dv && dv.sku) ? dv.sku : ('SP' + product.id); %>

    <div class="container pd">
        <!-- Breadcrumb -->
        <nav class="breadcrumb">
            <a href="/"><%= t.product.home %></a>
            <% breadcrumb.forEach(function (b) { %>
                <span class="sep">/</span><a href="/categories/<%= b.id %>"><%= pick(b, 'name') %></a>
            <% }) %>
            <span class="sep">/</span><span class="crumb-current"><%= pick(product, 'name') %></span>
        </nav>


        <%
        /* Gallery: hiện tối đa 7 ảnh. Nếu còn ảnh nữa thì ảnh thứ 7 bị làm mờ và
           gắn nút "Xem thêm" ở giữa để xổ phần còn lại. */
        const VISIBLE = 7;
        const shown = gallery.slice(0, VISIBLE);
        const hidden = gallery.slice(VISIBLE);

        /* Ảnh ĐẦU giữ nguyên như trước: to, tràn bề ngang.
           Từ ảnh thứ hai trở đi mới xếp khảm, lặp theo chu kỳ 6 trên lưới 6 cột:
             1-2: hai ô nửa bề ngang     4:   ô rộng 2/3
             3:   ô hẹp 1/3              5-6: hai ô tràn bề ngang

           Gán lớp theo CHỈ SỐ ẢNH, không dùng :nth-child — trong lưới còn có nút
           "Xem thêm", nth-child sẽ đếm cả nó và làm lệch nhịp toàn bộ từ đó. */
        const SPANS = ['s3', 's3', 's2', 's4', 's6', 's6'];
        const W = {s2: 2, s3: 3, s4: 4, s6: 6};
        const BY_W = {2: 's2', 3: 's3', 4: 's4', 5: 's6', 6: 's6'};

        /* Trả về mảng lớp cho `n` ảnh khảm (KHÔNG tính ảnh đầu).
           Ô CUỐI được nới cho kín hàng: chu kỳ bị cắt giữa chừng sẽ để lại ô lẻ
           chiếm nửa hàng, bỏ trống phần còn lại — nhìn như vỡ layout. Xảy ra với
           số ảnh chia 6 dư 1 (còn mỗi s3) hoặc dư 3 (còn mỗi s2). */
        function mosaic(n) {
            const out = [];
            for (let i = 0; i < n; i++) out.push(SPANS[i % SPANS.length]);
            let col = 0;
            for (let i = 0; i < out.length; i++) {
                if (col + W[out[i]] > 6) col = 0;   // tràn -> xuống hàng mới
                col += W[out[i]];
                if (i === out.length - 1 && col < 6) out[i] = BY_W[W[out[i]] + (6 - col)];
            }
            return out;
        }

        // Ảnh đầu luôn to tràn bề ngang; phần còn lại xếp khảm.
        // Ô cuối của `shown` sẽ bị ép s6 làm teaser nếu còn ảnh ẩn -> tính khảm
        // cho phần TRƯỚC nó thôi, khỏi nới thừa một ô rồi lại ghi đè.
        const teaserAt = hidden.length ? shown.length - 1 : -1;
        const shownSpans = mosaic(Math.max(0, (teaserAt < 0 ? shown.length : teaserAt) - 1));
        const hiddenSpans = mosaic(hidden.length);
        %>
        <div class="pd-top">
            <div class="pd-gallery" id="pdGallery">
                <% shown.forEach(function (src, i) { %>
                    <%
                    // i === 0        -> ảnh to tràn bề ngang, giữ như bố cục cũ
                    // i === teaserAt -> ảnh mờ mang nút "Xem thêm", ép tràn bề ngang
                    //                   để nút không rơi vào ô hẹp 1/3
                    const cls = i === 0 ? 'is-lead'
                        : (i === teaserAt ? 's6 is-teaser' : shownSpans[i - 1]);
                    %>
                    <figure class="pdg-cell <%= cls %>">
                        <img src="<%= src %>" alt="<%= pick(product, 'name') %>" loading="<%= i === 0 ? 'eager' : 'lazy' %>">
                    </figure>
                <% }) %>

                <% if (hidden.length) { %>
                    <button class="pdg-more" type="button" id="pdgMore" aria-controls="pdGallery" aria-expanded="false">
                        <span aria-hidden="true">⌄</span> <%= t.product.showMore %>
                    </button>
                    <%# Ảnh còn lại render sẵn nhưng ẩn — bấm là hiện ngay, không phải tải thêm.
                        Tính khảm riêng cho nhóm này, bắt đầu lại chu kỳ: ô teaser phía trên
                        đã chiếm trọn một hàng nên nối tiếp nhịp cũ không còn ý nghĩa. %>
                    <% hidden.forEach(function (src, k) { %>
                        <figure class="pdg-cell pdg-extra <%= hiddenSpans[k] %>" hidden>
                            <img src="<%= src %>" alt="<%= pick(product, 'name') %>" loading="lazy">
                        </figure>
                    <% }) %>
                <% } %>
            </div>

            <%# Cột phải GHIM CỐ ĐỊNH khi cuộn gallery bên trái %>
            <div class="pd-info is-sticky">
                <h1 class="pd-name"><%= pick(product, 'name') %></h1>
                <%# Dòng giá đã bỏ theo yêu cầu (bỏ giá trên toàn bộ trang khách xem). %>
                <p class="pd-desc"><%= pick(product, 'description') || t.product.noDescription %></p>

                <% if (product.variants && product.variants.length) { %>
                    <div class="pd-variants">
                        <span class="pd-variant-label"><%= t.product.variantLabel %>:</span>
                        <div class="variant-list">
                            <% product.variants.forEach(function (v, i) { %>
                                <%# `data-price` đã bỏ: để lại thì giá vẫn nằm nguyên trong
                                    mã nguồn trang, xem "View source" là đọc được — bỏ giá
                                    kiểu đó coi như không bỏ. %>
                                <button class="variant <%= i === 0 ? 'active' : '' %>"
                                        data-image="<%= v.image || '' %>"
                                        data-sku="<%= v.sku || ('SP' + product.id) %>">
                                    <% if (v.image) { %><img src="<%= v.image %>" alt="<%= v.name %>"><% } %>
                                    <span><%= v.name %></span>
                                </button>
                            <% }) %>
                        </div>
                    </div>
                <% } %>

                <div class="pd-meta">
                    <div><span class="pd-meta-k"><%= t.product.sku %>:</span> <span id="pdSku"><%= initSku %></span></div>
                    <% if (breadcrumb.length) { %>
                        <div>
                            <span class="pd-meta-k"><%= t.product.categories %>:</span>
                            <% breadcrumb.forEach(function (b, i) { %><a class="pd-cat" href="/categories/<%= b.id %>"><%= pick(b, 'name') %></a><%= i < breadcrumb.length - 1 ? ', ' : '' %><% }) %>
                        </div>
                    <% } %>
                </div>

                <a class="btn btn-primary pd-cta" href="#footer"><%= t.product.contact %> &rarr;</a>
            </div>
        </div>

        <!-- Tabs -->
        <div class="tabs">
            <%# Bỏ tab "Câu hỏi thường gặp", giữ "Đóng gói & vận chuyển" %>
            <div class="tab-nav">
                <button class="tab-btn active" data-tab="additional"><%= t.product.tabs.additional %></button>
                <button class="tab-btn" data-tab="packaging"><%= t.product.tabs.packaging %></button>
            </div>

            <div class="tab-panel active" id="tab-additional">
                <div class="tab-2col">
                    <div>
                        <h3 class="tab-h"><%= t.product.specsTitle %></h3>
                        <%
                        /* Ưu tiên thông số THẬT từ DB; sản phẩm chưa nhập thì mới
                           rơi về bảng mẫu trong file ngôn ngữ. */
                        const realSpecs = [
                            {label: t.product.attrs.size, value: pick(product, 'dimensions')},
                            {label: t.product.attrs.weight, value: product.weight != null ? Number(product.weight) + ' kg' : ''},
                            {label: t.product.attrs.material, value: pick(product, 'material')},
                            {label: t.product.attrs.color, value: pick(product, 'color')},
                        ].filter(function (s) { return s.value; });
                        const specRows = realSpecs.length ? realSpecs : t.product.specs;
                        %>
                        <table class="spec-table">
                            <% specRows.forEach(function (s) { %>
                                <tr><th><%= s.label %></th><td><%= s.value %></td></tr>
                            <% }) %>
                        </table>
                    </div>
                    <div class="tab-img" style="background-image:url('<%= gallery[0] %>')"></div>
                </div>

                <%# Thông tin thêm do admin soạn. bodyHtml dựng từ richtext.helper
                    (escape trước, sinh thẻ sau) nên in thô ở đây là an toàn. %>
                <% if (extraHtml) { %>
                    <div class="article-body tab-richtext"><%- extraHtml %></div>
                <% } %>
            </div>

            <div class="tab-panel" id="tab-packaging">
                <%# Nội dung vận chuyển admin nhập được ưu tiên; chưa nhập thì dùng chữ mẫu %>
                <% if (shippingHtml) { %>
                    <div class="article-body tab-richtext"><%- shippingHtml %></div>
                <% } else { %>
                    <p class="tab-desc"><%= t.product.packagingDesc %></p>
                <% } %>
                <table class="spec-table">
                    <% t.product.packaging.forEach(function (s) { %>
                        <tr><th><%= s.label %></th><td><%= s.value %></td></tr>
                    <% }) %>
                </table>
                <a class="btn btn-outline pd-cta" href="#footer"><%= t.product.contact %> &rarr;</a>
            </div>

        </div>

        <%# Sản phẩm liên quan — ngẫu nhiên cùng danh mục (RAND() ở SQL) %>
        <% if (related.length) { %>
            <section class="pd-related">
                <h2 class="pd-related-title"><%= t.product.related %></h2>
                <div class="product-grid">
                    <% related.forEach(function (p) { %>
                        <a class="product-card" href="/products/<%= p.id %>">
                            <div class="product-thumb" style="background-image:url('<%= p.thumbnail || ('https://picsum.photos/seed/p' + p.id + '/400') %>')">
                                <% if (p.is_featured) { %><span class="badge-hot">HOT</span><% } %>
                            </div>
                            <div class="product-info">
                                <h3 class="product-name"><%= pick(p, 'name') %></h3>
                                <% if (pick(p, 'material')) { %><p class="product-attr"><%= pick(p, 'material') %></p><% } %>
                                <%# Giá đã bỏ khỏi TOÀN BỘ trang khách xem theo yêu cầu. %>
                            </div>
                        </a>
                    <% }) %>
                </div>
            </section>
        <% } %>
    </div>
<% } %>

<%- include('partials/footer') %>
<script src="/static/js/main.js?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : '1' %>"></script>
</body>
</html>
