<%- include('../partials/head') %>
<body class="admin">
<%- include('_nav', {section: 'content'}) %>
<main class="admin-wrap admin-narrow">
    <div class="admin-head">
        <h1>Nội dung trang chủ</h1>
        <a class="btn-sm" href="/" target="_blank" rel="noopener">Xem site ↗</a>
    </div>
    <% if (flash) { %><div class="admin-flash"><%= flash %></div><% } %>

    <form class="admin-form" method="post" action="/admin/content">
        <h2 class="admin-subhead">Khối “Loại sản phẩm”</h2>
        <p class="admin-hint">Bỏ trống thì trang chủ dùng lại chữ mặc định trong file ngôn ngữ.</p>

        <div class="form-2col">
            <div>
                <label>Tiêu đề (VI)</label>
                <textarea name="<%= keys.CAT_TITLE_VI %>" rows="2" maxlength="500"><%= values[keys.CAT_TITLE_VI] || '' %></textarea>
            </div>
            <div>
                <label>Tiêu đề (EN)</label>
                <textarea name="<%= keys.CAT_TITLE_EN %>" rows="2" maxlength="500"><%= values[keys.CAT_TITLE_EN] || '' %></textarea>
            </div>
            <div>
                <label>Mô tả (VI)</label>
                <textarea name="<%= keys.CAT_DESC_VI %>" rows="4" maxlength="500"><%= values[keys.CAT_DESC_VI] || '' %></textarea>
            </div>
            <div>
                <label>Mô tả (EN)</label>
                <textarea name="<%= keys.CAT_DESC_EN %>" rows="4" maxlength="500"><%= values[keys.CAT_DESC_EN] || '' %></textarea>
            </div>
        </div>

        <h2 class="admin-subhead">Khối “Tin tức”</h2>
        <div class="form-2col">
            <div>
                <label>Tiêu đề (VI)</label>
                <textarea name="<%= keys.NEWS_TITLE_VI %>" rows="2" maxlength="500"><%= values[keys.NEWS_TITLE_VI] || '' %></textarea>
            </div>
            <div>
                <label>Tiêu đề (EN)</label>
                <textarea name="<%= keys.NEWS_TITLE_EN %>" rows="2" maxlength="500"><%= values[keys.NEWS_TITLE_EN] || '' %></textarea>
            </div>
            <div>
                <label>Mô tả (VI)</label>
                <textarea name="<%= keys.NEWS_DESC_VI %>" rows="4" maxlength="500"><%= values[keys.NEWS_DESC_VI] || '' %></textarea>
            </div>
            <div>
                <label>Mô tả (EN)</label>
                <textarea name="<%= keys.NEWS_DESC_EN %>" rows="4" maxlength="500"><%= values[keys.NEWS_DESC_EN] || '' %></textarea>
            </div>
            <div><label>Nhãn nút (VI)</label><input name="<%= keys.NEWS_CTA_VI %>" value="<%= values[keys.NEWS_CTA_VI] || '' %>" placeholder="Khám phá xu hướng"></div>
            <div><label>Nhãn nút (EN)</label><input name="<%= keys.NEWS_CTA_EN %>" value="<%= values[keys.NEWS_CTA_EN] || '' %>" placeholder="Explore trends"></div>
        </div>
        <label>Link nút</label>
        <input name="<%= keys.NEWS_CTA_LINK %>" value="<%= values[keys.NEWS_CTA_LINK] || '' %>" placeholder="/#news">

        <div class="form-actions">
            <button class="btn btn-primary" type="submit">Lưu thay đổi</button>
        </div>
    </form>
</main>
<script src="/static/js/admin.js"></script>
</body>
</html>
