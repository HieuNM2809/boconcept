<%- include('../partials/head') %>
<body class="admin">
<%- include('_nav', {section: 'gallery'}) %>
<main class="admin-wrap">
    <div class="admin-head">
        <h1>Lưới ảnh trang chủ</h1>
    </div>
    <% if (flash) { %><div class="admin-flash"><%= flash %></div><% } %>

    <div class="admin-toggle-bar">
        <div>
            <strong>3 ô lớn của lưới ảnh “Tư vấn phong cách”.</strong>
            <span class="admin-hint">
                Mỗi khe gắn cố định với một vị trí trên trang chủ — sửa ảnh của khe nào
                thì đúng ô đó đổi. Các ô nhỏ xung quanh được cài cứng trong mã nguồn,
                không sửa ở đây.
            </span>
        </div>
    </div>

    <table class="admin-table">
        <thead>
        <tr><th>Vị trí</th><th>Ảnh</th><th>Mô tả (VI)</th><th>Mô tả (EN)</th><th></th></tr>
        </thead>
        <tbody>
        <% items.forEach(function (g) { %>
            <tr>
                <td><strong><%= g.label %></strong></td>
                <td><img class="admin-thumb" src="<%= g.image %>" alt="" loading="lazy"></td>
                <td><%= g.alt_vi || '—' %></td>
                <td><%= g.alt_en || '—' %></td>
                <td class="admin-row-actions">
                    <a class="btn-sm" href="/admin/gallery/<%= g.slot %>/edit">Sửa</a>
                </td>
            </tr>
        <% }) %>
        </tbody>
    </table>
</main>
<script src="/static/js/admin.js"></script>
</body>
</html>
