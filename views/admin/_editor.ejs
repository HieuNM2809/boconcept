<%
/* Ô soạn nội dung dùng chung cho MỌI form admin: thanh công cụ + textarea.
   Tham số: name (bắt buộc), value, rows, tools

   `tools` chọn các nút hiện ra, theo thứ tự nhóm cố định bên dưới:
       b · i · h2 · h3 · ul · link       (mặc định: đủ cả 6)

   VÌ SAO KHÔNG DÙNG Quill/TinyMCE/CKEditor: các thư viện đó xuất ra HTML, mà
   app/Helpers/richtext.helper.js cố ý ESCAPE TOÀN BỘ nội dung rồi mới dựng lại
   một tập thẻ do chính nó sinh — nên HTML của editor sẽ hiện ra thành chữ thô
   trên trang. Muốn dùng chúng thì phải lưu HTML và sanitize ở server, mà repo
   không có sanitize-html/DOMPurify; tự lọc bằng regex là đường dẫn thẳng tới
   stored XSS. Ở đây giữ nội dung là CHỮ THUẦN (Markdown rút gọn) và chỉ làm
   thanh công cụ cho tử tế. */
const e = {
    name: name,
    value: typeof value !== 'undefined' && value ? value : '',
    rows: typeof rows !== 'undefined' ? rows : 10,
    tools: typeof tools !== 'undefined' ? tools : ['b', 'i', 'h2', 'h3', 'ul', 'link'],
};
const has = (k) => e.tools.indexOf(k) !== -1;
// Vạch ngăn chỉ vẽ khi CẢ HAI nhóm nó ngăn cách đều có nút — không thì thanh
// công cụ của ô "vận chuyển" (chỉ B/I/danh sách) sẽ có vạch cụt lơ lửng.
const gHead = has('h2') || has('h3');
const gIns = has('ul') || has('link');
%>

<div class="editor">
    <div class="editor-toolbar" data-editor-for="<%= e.name %>" role="toolbar" aria-label="Định dạng nội dung">
        <div class="editor-group">
            <% if (has('b')) { %><button type="button" data-wrap="**" title="Đậm (Ctrl+B)" aria-label="Đậm"><b>B</b></button><% } %>
            <% if (has('i')) { %><button type="button" data-wrap="*" title="Nghiêng (Ctrl+I)" aria-label="Nghiêng"><i>I</i></button><% } %>
        </div>

        <% if (gHead) { %><span class="editor-sep" aria-hidden="true"></span>
        <div class="editor-group">
            <% if (has('h2')) { %><button type="button" data-prefix="## " title="Tiêu đề mức 2">H2</button><% } %>
            <% if (has('h3')) { %><button type="button" data-prefix="### " title="Tiêu đề mức 3">H3</button><% } %>
        </div><% } %>

        <% if (gIns) { %><span class="editor-sep" aria-hidden="true"></span>
        <div class="editor-group">
            <% if (has('ul')) { %>
                <button type="button" data-prefix="- " title="Gạch đầu dòng">
                    <svg class="editor-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                        <circle cx="3" cy="4" r="1.1" fill="currentColor" stroke="none"/><path d="M6.5 4h7"/>
                        <circle cx="3" cy="8" r="1.1" fill="currentColor" stroke="none"/><path d="M6.5 8h7"/>
                        <circle cx="3" cy="12" r="1.1" fill="currentColor" stroke="none"/><path d="M6.5 12h7"/>
                    </svg>Danh sách</button>
            <% } %>
            <% if (has('link')) { %>
                <button type="button" data-link="1" title="Chèn liên kết">
                    <svg class="editor-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M6.6 9.4a2.8 2.8 0 0 0 4 0l2.2-2.2a2.8 2.8 0 1 0-4-4l-1 1"/>
                        <path d="M9.4 6.6a2.8 2.8 0 0 0-4 0L3.2 8.8a2.8 2.8 0 1 0 4 4l1-1"/>
                    </svg>Link</button>
            <% } %>
        </div><% } %>

        <%# Xem trước đẩy sang phải, tách hẳn khỏi nhóm nút chèn: nó không chèn gì
            vào nội dung mà đổi chế độ hiển thị của cả ô. %>
        <button type="button" class="editor-preview-btn" data-preview="1"
                title="Xem trước (Ctrl+Shift+P)" aria-pressed="false">
            <svg class="editor-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M1.5 8S3.9 3.5 8 3.5 14.5 8 14.5 8 12.1 12.5 8 12.5 1.5 8 1.5 8Z"/>
                <circle cx="8" cy="8" r="2.1"/>
            </svg><span class="editor-preview-label">Xem trước</span>
        </button>
    </div>

    <textarea id="<%= e.name %>" name="<%= e.name %>" rows="<%= e.rows %>" class="editor-area"><%= e.value %></textarea>
    <%# Khung xem trước dùng chính class .article-body của trang public để chữ,
        tiêu đề và link hiện y hệt lúc đăng — khác class là xem trước nói dối. %>
    <%# KHÔNG dùng tên data-preview-for: attribute đó đã là của ảnh xem trước
        trong dòng bộ sưu tập (bindEncoders tra theo nó). %>
    <div class="editor-preview article-body" data-preview-pane="<%= e.name %>" hidden></div>
</div>
