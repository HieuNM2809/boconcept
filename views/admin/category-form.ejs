<%- include('../partials/head') %>
<body class="admin">
<%- include('_nav', {section: 'categories'}) %>
<%# Không dùng admin-narrow (720px): form có 2 ô soạn thảo mô tả VI/EN, bó vào
    cột hẹp thì gõ rất bí — cho dãn hết màn hình như /admin/pages. %>
<main class="admin-wrap">
    <div class="admin-head">
        <h1><%= item ? ('Sửa loại #' + item.id) : 'Thêm loại sản phẩm' %></h1>
        <a class="btn-sm" href="/admin/categories">← Quay lại</a>
    </div>
    <form class="admin-form" method="post" action="<%= action %>">
        <div class="form-2col">
            <div><label>Tên (VI) *</label><input name="name_vi" required value="<%= item ? item.name_vi : '' %>"></div>
            <div><label>Tên (EN)</label><input name="name_en" value="<%= item ? (item.name_en || '') : '' %>"></div>
        </div>
        <%- include('_image-field', {name: 'image', label: 'Ảnh loại sản phẩm', value: item ? (item.image || '') : ''}) %>

        <h2 class="admin-subhead">Tiêu đề & mô tả (hiện ở đầu trang danh sách)</h2>
        <p class="admin-hint">Để trống thì trang dùng luôn “Tên” ở trên làm tiêu đề.</p>
        <div class="form-2col">
            <div><label>Tiêu đề (VI)</label><input name="title_vi" value="<%= item ? (item.title_vi || '') : '' %>"></div>
            <div><label>Tiêu đề (EN)</label><input name="title_en" value="<%= item ? (item.title_en || '') : '' %>"></div>
        </div>

        <p class="admin-hint">
            Định dạng: <code>**đậm**</code> · <code>*nghiêng*</code> · <code>## Tiêu đề</code> ·
            <code>- gạch đầu dòng</code>. Thẻ HTML gõ vào sẽ hiện dạng chữ, không chạy.
        </p>
        <label>Mô tả (VI)</label>
        <%- include('_editor', {name: 'description_vi', rows: 5, value: item ? (item.description_vi || '') : '', tools: 'full'}) %>
        <label>Mô tả (EN)</label>
        <%- include('_editor', {name: 'description_en', rows: 5, value: item ? (item.description_en || '') : '', tools: 'full'}) %>

        <div class="form-auto">
            <div>
                <label>Danh mục cha</label>
                <select name="parent_id">
                    <option value="">— Không (cấp 1) —</option>
                    <% parents.forEach(function (p) { %>
                        <option value="<%= p.id %>" <%= (item && item.parent_id === p.id) ? 'selected' : '' %>><%= p.name_vi %></option>
                    <% }) %>
                </select>
            </div>
            <div><label>Slug</label><input name="slug" value="<%= item ? (item.slug || '') : '' %>"></div>
            <div><label>Thứ tự</label><input type="number" name="sort_order" value="<%= item ? item.sort_order : 0 %>"></div>
            <div><label>Nổi bật (ghim lên đầu trang chủ)</label>
                <select name="is_featured">
                    <option value="0" <%= (!item || !item.is_featured) ? 'selected' : '' %>>Không</option>
                    <option value="1" <%= (item && item.is_featured) ? 'selected' : '' %>>Có</option>
                </select>
            </div>
            <div><label>Trạng thái</label>
                <select name="status">
                    <option value="1" <%= (!item || item.status) ? 'selected' : '' %>>Hiện</option>
                    <option value="0" <%= (item && !item.status) ? 'selected' : '' %>>Ẩn</option>
                </select>
            </div>
        </div>
        <div class="form-actions">
            <button class="btn btn-primary" type="submit"><%= item ? 'Lưu thay đổi' : 'Thêm' %></button>
            <a class="btn btn-outline" href="/admin/categories">Hủy</a>
        </div>
    </form>
</main>
<script src="/static/js/admin.js"></script>
</body>
</html>
