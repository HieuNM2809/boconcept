<%- include('../partials/head') %>
<body class="admin">
<%- include('_nav', {section: 'gallery'}) %>
<main class="admin-wrap admin-narrow">
    <div class="admin-head">
        <h1><%= label %></h1>
        <a class="btn-sm" href="/admin/gallery">← Quay lại</a>
    </div>
    <form class="admin-form" method="post" action="<%= action %>">

        <label>Ảnh *</label>
        <div class="form-upload">
            <%# 400KB: base64 phình ~33% -> ~533KB, vẫn dưới giới hạn 1mb của body parser %>
            <input type="file" id="imageFile" accept="image/*" data-encode-to="image">
            <span class="admin-hint">Chọn file (tối đa 400KB) hoặc dán đường dẫn vào ô dưới.</span>
        </div>
        <input name="image" id="image" required value="<%= item.image %>" placeholder="https://...">
        <img class="form-preview" id="imagePreview" src="<%= item.image %>" alt="">

        <div class="form-2col">
            <div><label>Mô tả ảnh (VI)</label><input name="alt_vi" value="<%= item.alt_vi || '' %>" placeholder="Dùng cho trình đọc màn hình"></div>
            <div><label>Mô tả ảnh (EN)</label><input name="alt_en" value="<%= item.alt_en || '' %>"></div>
        </div>

        <div class="form-actions">
            <button class="btn btn-primary" type="submit">Lưu thay đổi</button>
            <a class="btn btn-outline" href="/admin/gallery">Hủy</a>
        </div>
    </form>
</main>
<script src="/static/js/admin.js"></script>
</body>
</html>
