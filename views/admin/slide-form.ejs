<%- include('../partials/head') %>
<body class="admin">
<%- include('_nav', {section: 'slides'}) %>

<%# Bố cục 2 cột như form sản phẩm nhưng ĐẢO VAI: ở đây ảnh chính là nội dung
    (slide vốn là banner ngang), còn chữ chỉ có 5 ô ngắn — nên ảnh chiếm cột lớn
    bên trái, chữ và thiết lập dồn sang cột phải. %>
<main class="admin-wrap">
    <div class="admin-head">
        <h1><%= slide ? ('Sửa slide #' + slide.id) : 'Thêm slide' %></h1>
        <a class="btn-sm" href="/admin/slides">← Quay lại</a>
    </div>

    <form class="admin-form admin-form-wide" method="post" action="<%= action %>">
        <div class="form-main">
            <section class="form-card is-media">
                <%# previewClass is-wide: ảnh xem trước cao tới 380px thay vì 200px như
                    ảnh thumbnail sản phẩm — cột này rộng, mà slide phải nhìn được cả
                    bố cục chữ trên ảnh mới biết có bị che hay không. %>
                <%- include('_image-field', {name: 'image', label: 'Ảnh slide', value: slide ? slide.image : '', required: true, previewClass: 'is-wide'}) %>
            </section>
        </div>

        <aside class="form-side">
            <section class="form-card">
                <h2 class="admin-subhead">Nội dung hiện trên ảnh</h2>
                <label for="title_vi">Tiêu đề (VI)</label>
                <input id="title_vi" name="title_vi" value="<%= slide ? (slide.title_vi || '') : '' %>">
                <label for="title_en">Tiêu đề (EN)</label>
                <input id="title_en" name="title_en" value="<%= slide ? (slide.title_en || '') : '' %>">
                <label for="badge_vi">Badge (VI)</label>
                <input id="badge_vi" name="badge_vi" value="<%= slide ? (slide.badge_vi || '') : '' %>">
                <label for="badge_en">Badge (EN)</label>
                <input id="badge_en" name="badge_en" value="<%= slide ? (slide.badge_en || '') : '' %>">
            </section>

            <section class="form-card">
                <h2 class="admin-subhead">Hiển thị</h2>
                <label for="sort_order">Thứ tự hiển thị</label>
                <input type="number" id="sort_order" name="sort_order" value="<%= slide ? slide.sort_order : 0 %>">
                <label for="status">Trạng thái</label>
                <select id="status" name="status">
                    <option value="1" <%= (!slide || slide.status) ? 'selected' : '' %>>Hiện</option>
                    <option value="0" <%= (slide && !slide.status) ? 'selected' : '' %>>Ẩn</option>
                </select>

                <div class="form-actions">
                    <button class="btn btn-primary" type="submit"><%= slide ? 'Lưu thay đổi' : 'Thêm slide' %></button>
                    <a class="btn btn-outline" href="/admin/slides">Hủy</a>
                </div>
            </section>
        </aside>
    </form>
</main>

<script src="/static/js/admin.js"></script>
</body>
</html>
