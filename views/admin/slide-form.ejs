<%- include('../partials/head') %>
<body class="admin">
<%- include('_nav', {section: 'slides'}) %>

<main class="admin-wrap admin-narrow">
    <div class="admin-head">
        <h1><%= slide ? ('Sửa slide #' + slide.id) : 'Thêm slide' %></h1>
        <a class="btn-sm" href="/admin/slides">← Quay lại</a>
    </div>

    <form class="admin-form" method="post" action="<%= action %>">
        <%- include('_image-field', {name: 'image', label: 'Ảnh slide', value: slide ? slide.image : '', required: true}) %>

        <div class="form-2col">
            <div>
                <label>Tiêu đề (VI)</label>
                <input name="title_vi" value="<%= slide ? (slide.title_vi || '') : '' %>">
            </div>
            <div>
                <label>Tiêu đề (EN)</label>
                <input name="title_en" value="<%= slide ? (slide.title_en || '') : '' %>">
            </div>
            <div>
                <label>Badge (VI)</label>
                <input name="badge_vi" value="<%= slide ? (slide.badge_vi || '') : '' %>">
            </div>
            <div>
                <label>Badge (EN)</label>
                <input name="badge_en" value="<%= slide ? (slide.badge_en || '') : '' %>">
            </div>
            <div>
                <label>Thứ tự hiển thị</label>
                <input type="number" name="sort_order" value="<%= slide ? slide.sort_order : 0 %>">
            </div>
        </div>

        <label>Trạng thái</label>
        <select name="status">
            <option value="1" <%= (!slide || slide.status) ? 'selected' : '' %>>Hiện</option>
            <option value="0" <%= (slide && !slide.status) ? 'selected' : '' %>>Ẩn</option>
        </select>

        <div class="form-actions">
            <button class="btn btn-primary" type="submit"><%= slide ? 'Lưu thay đổi' : 'Thêm slide' %></button>
            <a class="btn btn-outline" href="/admin/slides">Hủy</a>
        </div>
    </form>
</main>

<script src="/static/js/admin.js"></script>
</body>
</html>
