<%- include('../partials/head') %>
<body class="admin">
<%- include('_nav', {section: 'certificates'}) %>
<main class="admin-wrap">
    <div class="admin-head">
        <h1>Giấy chứng nhận công ty</h1>
        <a class="btn btn-primary" href="/admin/certificates/new">+ Thêm chứng nhận</a>
    </div>
    <% if (flash) { %><div class="admin-flash"><%= flash %></div><% } %>
    <table class="admin-table">
        <thead>
        <tr><th>#</th><th>Ảnh</th><th>Tiêu đề (VI)</th><th>Tiêu đề (EN)</th><th>Thứ tự</th><th>Trạng thái</th><th></th></tr>
        </thead>
        <tbody>
        <% if (!items.length) { %><tr><td colspan="7" class="admin-empty">Chưa có chứng nhận.</td></tr><% } %>
        <% items.forEach(function (c) { %>
            <tr>
                <td><%= c.id %></td>
                <td><img class="admin-thumb" src="<%= c.image %>" alt="" loading="lazy"></td>
                <td><%= c.title_vi || '—' %></td>
                <td><%= c.title_en || '—' %></td>
                <td><%= c.sort_order %></td>
                <td><span class="badge-status <%= c.status ? 'on' : 'off' %>"><%= c.status ? 'Hiện' : 'Ẩn' %></span></td>
                <td class="admin-row-actions">
                    <a class="btn-sm" href="/admin/certificates/<%= c.id %>/edit">Sửa</a>
                    <form method="post" action="/admin/certificates/<%= c.id %>/delete" data-confirm="Xóa chứng nhận này?"><button class="btn-sm danger" type="submit">Xóa</button></form>
                </td>
            </tr>
        <% }) %>
        </tbody>
    </table>
</main>
<script src="/static/js/admin.js"></script>
</body>
</html>
