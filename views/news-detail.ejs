<%- include('partials/head') %>
<body>
<%- include('partials/header') %>

<% if (!post) { %>
    <section class="section">
        <div class="container center">
            <h2 class="section-title"><%= t.news.notFound %></h2>
            <a class="btn btn-outline" href="/news"><%= t.news.backToList %></a>
        </div>
    </section>
<% } else { %>
    <div class="container">
        <nav class="breadcrumb">
            <a href="/"><%= t.news.home %></a>
            <span class="sep">/</span><a href="/news"><%= t.news.title %></a>
            <span class="sep">/</span><span class="crumb-current"><%= pick(post, 'title') %></span>
        </nav>

        <article class="article">
            <h1 class="article-title"><%= pick(post, 'title') %></h1>

            <p class="article-meta">
                <% if (post.published_at) { %>
                    <time datetime="<%= new Date(post.published_at).toISOString() %>">
                        <%= new Date(post.published_at).toLocaleDateString(lang === 'en' ? 'en-GB' : 'vi-VN', {day: 'numeric', month: 'long', year: 'numeric'}) %>
                    </time>
                <% } %>
                <% if (post.author) { %>
                    <% if (post.published_at) { %><span class="sep">·</span><% } %>
                    <%= t.news.by %> <strong><%= post.author %></strong>
                <% } %>
            </p>

            <% if (pick(post, 'excerpt')) { %>
                <p class="article-lead"><%= pick(post, 'excerpt') %></p>
            <% } %>

            <% if (post.image) { %>
                <figure class="article-hero">
                    <img src="<%= post.image %>" alt="<%= pick(post, 'title') %>">
                </figure>
            <% } %>

            <%# bodyHtml do richtext.helper dựng ra: nó escape toàn bộ đầu vào rồi
                mới sinh một tập thẻ cố định, nên việc in thô ở đây KHÔNG mở đường
                cho XSS. Tuyệt đối không in thô bất kỳ chuỗi nào khác của người dùng. %>
            <div class="article-body">
                <% if (bodyHtml) { %>
                    <%- bodyHtml %>
                <% } else { %>
                    <p class="empty"><%= t.news.noBody %></p>
                <% } %>
            </div>

            <p class="article-back">
                <a class="btn btn-outline" href="/news">&larr; <%= t.news.backToList %></a>
            </p>
        </article>

        <% if (related.length) { %>
            <section class="pd-related">
                <h2 class="pd-related-title"><%= t.news.otherPosts %></h2>
                <div class="news-grid news-grid-3">
                    <% related.forEach(function (n) { %>
                        <article class="news-card">
                            <a class="news-card-media" href="/news/<%= n.id %>">
                                <img src="<%= n.image %>" alt="<%= pick(n, 'title') %>" loading="lazy">
                            </a>
                            <h3 class="news-card-title"><a href="/news/<%= n.id %>"><%= pick(n, 'title') %></a></h3>
                        </article>
                    <% }) %>
                </div>
            </section>
        <% } %>
    </div>
<% } %>

<%- include('partials/footer') %>
<script src="/static/js/main.js?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : '1' %>"></script>
</body>
</html>
