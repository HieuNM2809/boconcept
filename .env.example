APP_ENV=local
NODE_ENV=development
PORT=3000
PORT_SCHEDULE=3005

# HTTP / bảo mật
CORS_ORIGIN=*
BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
TOKEN_EXPIRES_IN=24h

# MySQL / Sequelize
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DIALECT=mysql
DB_NAME=app_db
DB_USER=root
DB_PASS=root
DB_POOL_MAX=50
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
DB_RETRY_MAX=3

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
